<UserControl x:Class="Usage4Claude.Controls.UsageInfoRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="280" d:DesignHeight="32">
    <Border Background="#0A808080"
            CornerRadius="6"
            Padding="10,6">
        <DockPanel>
            <!-- Colored indicator dot -->
            <Ellipse DockPanel.Dock="Left"
                     Width="8" Height="8"
                     Fill="{Binding IndicatorColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />

            <!-- Value text on the right -->
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding ValueText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#666666" />

            <!-- Limit name in the center -->
            <TextBlock Text="{Binding LimitName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="#333333" />
        </DockPanel>
    </Border>
</UserControl>
