<UserControl x:Class="Usage4Claude.Controls.CircularProgress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="100" d:DesignHeight="100">
    <Grid Width="{Binding Size, RelativeSource={RelativeSource AncestorType=UserControl}}"
          Height="{Binding Size, RelativeSource={RelativeSource AncestorType=UserControl}}">

        <!-- Background track circle -->
        <Path Data="{Binding TrackGeometry, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Stroke="{Binding TrackColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
              StrokeThickness="{Binding StrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        <!-- Progress arc -->
        <Path x:Name="ProgressPath"
              Data="{Binding ArcGeometry, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Stroke="{Binding ActualProgressColor, RelativeSource={RelativeSource AncestorType=UserControl}}"
              StrokeThickness="{Binding StrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round" />

        <!-- Center text -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding ActualDisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="{Binding DisplayFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <TextBlock Text="{Binding SubText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="{Binding SubTextFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="Gray"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="{Binding SubTextVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </StackPanel>
    </Grid>
</UserControl>
