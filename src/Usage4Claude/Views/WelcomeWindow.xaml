<Window x:Class="Usage4Claude.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usage4Claude - Welcome"
        Width="500" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True">

    <Window.Resources>
        <!-- Primary action button style (matching the codebase convention) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#106EBE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC" />
                                <Setter Property="Foreground" Value="#999999" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card border style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Secondary / link button style -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="LinkText"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextDecorations="Underline"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="Foreground" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Step indicator dot (inactive) -->
        <Style x:Key="StepDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Fill" Value="#CCCCCC" />
            <Setter Property="Margin" Value="4,0" />
        </Style>

        <!-- Field label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Step indicators -->
            <RowDefinition Height="*" />     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Step indicator dots -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Ellipse x:Name="Dot1" Style="{StaticResource StepDot}" Fill="#0078D4" />
            <Ellipse x:Name="Dot2" Style="{StaticResource StepDot}" />
            <Ellipse x:Name="Dot3" Style="{StaticResource StepDot}" />
        </StackPanel>

        <!-- ===== STEP 1: Welcome ===== -->
        <Grid x:Name="Step1Panel" Grid.Row="1" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="40">
                <!-- App icon placeholder -->
                <TextBlock Text="Usage4Claude"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#0078D4"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <TextBlock Text="Welcome to Usage4Claude"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />

                <TextBlock Text="Monitor your Claude AI usage quotas from the system tray."
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40" />

                <Button Content="Get Started"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center"
                        Click="GetStarted_Click" />
            </StackPanel>
        </Grid>

        <!-- ===== STEP 2: Add Account ===== -->
        <Grid x:Name="Step2Panel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel Margin="40,20,40,20">
                <TextBlock Text="Add Your Account"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock Text="Choose how to connect your Claude account."
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <!-- Option 1: Browser Login Card -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                        IsEnabled="False" Opacity="0.5"
                        ToolTip="Browser login will be available in a future update.">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Browser Login"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#333333" Margin="0,0,0,4" />
                            <TextBlock Text="Sign in through your browser"
                                       FontSize="12" Foreground="#888888" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Sign In"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,8" FontSize="12"
                                IsEnabled="False"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Option 2: Manual Entry Card -->
                <Border Style="{StaticResource CardBorder}" Cursor="Arrow">
                    <StackPanel>
                        <TextBlock Text="Manual Entry"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#333333" Margin="0,0,0,4" />
                        <TextBlock Text="Enter session key manually"
                                   FontSize="12" Foreground="#888888"
                                   Margin="0,0,0,12" />

                        <!-- Organization ID -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Organization ID" />
                        <TextBox x:Name="ManualOrgIdBox"
                                 FontSize="12" Padding="6" Margin="0,0,0,8" />

                        <!-- Session Key -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Session Key" />
                        <PasswordBox x:Name="ManualSessionKeyBox"
                                     FontSize="12" Padding="6" Margin="0,0,0,12" />

                        <Button Content="Add Account"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,8" FontSize="12"
                                HorizontalAlignment="Left"
                                Click="ManualAdd_Click" />
                    </StackPanel>
                </Border>

                <!-- Skip link -->
                <Button Content="Skip for now"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0"
                        Click="Skip_Click" />
            </StackPanel>
        </Grid>

        <!-- ===== STEP 3: Ready ===== -->
        <Grid x:Name="Step3Panel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="40" Width="340">
                <TextBlock Text="You're All Set!"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />

                <TextBlock x:Name="ReadyDescription"
                           Text="Your account has been configured. Usage4Claude will now monitor your usage."
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Options -->
                <StackPanel Margin="0,0,0,32">
                    <CheckBox x:Name="LaunchAtLoginCheckBox"
                              Content="Launch at login"
                              IsChecked="False"
                              FontSize="13"
                              Margin="0,0,0,10" />

                    <CheckBox x:Name="NotificationsCheckBox"
                              Content="Enable notifications"
                              IsChecked="True"
                              FontSize="13" />
                </StackPanel>

                <Button Content="Finish"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center"
                        Click="Finish_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
