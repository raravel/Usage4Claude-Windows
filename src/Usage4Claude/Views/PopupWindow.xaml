<Window x:Class="Usage4Claude.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Usage4Claude.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Spinning animation for refresh button -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RefreshButtonRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360"
                             Duration="0:0:1" />
        </Storyboard>
    </Window.Resources>

    <!-- Outer border with shadow and rounded corners -->
    <Border CornerRadius="12"
            Background="#F0F0F0F0"
            BorderBrush="#20808080"
            BorderThickness="1"
            Width="300"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16"
                              ShadowDepth="2"
                              Opacity="0.3"
                              Color="Black" />
        </Border.Effect>

        <StackPanel Margin="16">

            <!-- Header row -->
            <DockPanel Margin="0,0,0,12">
                <!-- Refresh button on the right -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding RefreshCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4"
                        Cursor="Hand"
                        ToolTip="Refresh"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock x:Name="RefreshIcon"
                               Text="&#x21BB;"
                               FontSize="16"
                               Foreground="#666666"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="RefreshButtonRotation" Angle="0" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Button>

                <!-- App name on the left -->
                <TextBlock Text="Usage4Claude"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#333333"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Error view -->
            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="#10FF0000"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="&#x26A0; Error"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#D32F2F"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="11"
                               Foreground="#666666"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Usage content (visible when no error) -->
            <StackPanel x:Name="UsageContent">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Circular progress ring -->
                <controls:CircularProgress Value="{Binding FiveHourPercentage}"
                                           Size="120"
                                           StrokeThickness="10"
                                           SubText="used"
                                           IsAnimated="True"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,16"
                                           Cursor="Hand" />

                <!-- Usage info rows (clickable to toggle display mode) -->
                <StackPanel Margin="0,0,0,0"
                            Cursor="Hand"
                            MouseLeftButtonDown="InfoRows_MouseLeftButtonDown">
                    <StackPanel.Background>
                        <SolidColorBrush Color="Transparent" />
                    </StackPanel.Background>

                    <!-- 5-Hour row (always visible) -->
                    <controls:UsageInfoRow LimitName="5-Hour"
                                           ValueText="{Binding FiveHourDisplayValue}"
                                           IndicatorColor="#4CAF50"
                                           Margin="0,0,0,4" />

                    <!-- 7-Day row -->
                    <controls:UsageInfoRow LimitName="7-Day"
                                           ValueText="{Binding SevenDayDisplayValue}"
                                           IndicatorColor="#9C27B0"
                                           Margin="0,0,0,4">
                        <controls:UsageInfoRow.Style>
                            <Style TargetType="controls:UsageInfoRow">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SevenDayPercentage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:UsageInfoRow.Style>
                    </controls:UsageInfoRow>

                    <!-- Opus row -->
                    <controls:UsageInfoRow LimitName="Opus"
                                           ValueText="{Binding OpusDisplayValue}"
                                           IndicatorColor="#FF9800"
                                           Margin="0,0,0,4">
                        <controls:UsageInfoRow.Style>
                            <Style TargetType="controls:UsageInfoRow">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OpusPercentage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:UsageInfoRow.Style>
                    </controls:UsageInfoRow>

                    <!-- Sonnet row -->
                    <controls:UsageInfoRow LimitName="Sonnet"
                                           ValueText="{Binding SonnetDisplayValue}"
                                           IndicatorColor="#2196F3"
                                           Margin="0,0,0,4">
                        <controls:UsageInfoRow.Style>
                            <Style TargetType="controls:UsageInfoRow">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SonnetPercentage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:UsageInfoRow.Style>
                    </controls:UsageInfoRow>

                    <!-- Extra Usage row -->
                    <controls:UsageInfoRow LimitName="Extra Usage"
                                           IndicatorColor="#E91E63"
                                           ValueText="{Binding ExtraUsageText}"
                                           Visibility="{Binding HasExtraUsage, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <DockPanel Margin="0,12,0,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding AccountDisplayName}"
                           FontSize="10"
                           Foreground="#999999"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="10"
                           Foreground="#999999"
                           VerticalAlignment="Center" />
            </DockPanel>

        </StackPanel>
    </Border>
</Window>
