<Window x:Class="Usage4Claude.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Login to Claude"
        Width="800" Height="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />   <!-- WebView2 -->
            <RowDefinition Height="Auto" /> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- WebView2 control fills the window -->
        <wpf:WebView2 x:Name="WebView"
                       Grid.Row="0" />

        <!-- Status bar at the bottom -->
        <Border Grid.Row="1"
                Background="#F0F0F0"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Loading..."
                               FontSize="12"
                               Foreground="#555555"
                               VerticalAlignment="Center" />

                    <!-- Cancel button -->
                    <Button x:Name="CancelButton"
                            Grid.Column="1"
                            Content="Cancel"
                            Padding="16,4"
                            FontSize="12"
                            Cursor="Hand"
                            Click="CancelButton_Click"
                            IsCancel="True" />
                </Grid>

                <!-- Progress indicator during login -->
                <ProgressBar x:Name="StatusProgress"
                             IsIndeterminate="True"
                             Height="2"
                             Margin="0,4,0,0"
                             Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
