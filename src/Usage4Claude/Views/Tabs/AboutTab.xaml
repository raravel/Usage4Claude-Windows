<UserControl x:Class="Usage4Claude.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Reusable card border style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- Section title style -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Hint / description text style -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#E8E8E8" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#D0D0D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#C0C0C0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link button style -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="LinkBorder"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkBorder" Property="Background" Value="#10000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LinkBorder" Property="Background" Value="#18000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="16" HorizontalAlignment="Center">

        <!-- App icon placeholder + name + version -->
        <StackPanel HorizontalAlignment="Center" Margin="0,16,0,8">
            <!-- Icon placeholder (rounded rectangle) -->
            <Border Width="80" Height="80"
                    CornerRadius="16"
                    Background="#EEDCB7"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12">
                <TextBlock Text="U4C"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#8B6914"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- App name -->
            <TextBlock Text="Usage4Claude"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <!-- Version -->
            <TextBlock x:Name="VersionText"
                       Text="v1.0.0-dev"
                       FontSize="13"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Description -->
        <TextBlock Text="Monitor your Claude AI usage quotas from the Windows system tray. A Windows port of the original macOS app."
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   MaxWidth="380"
                   Margin="0,8,0,16" />

        <!-- Separator -->
        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,16" />

        <!-- Links Card -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Links" />

                <Button Style="{StaticResource LinkButton}"
                        Click="OpenGitHub_Click">
                    <TextBlock FontSize="12">
                        <Run Text="&#x1F310; " /><Run Text="GitHub Repository" Foreground="#0066CC" TextDecorations="Underline" />
                    </TextBlock>
                </Button>

                <Button Style="{StaticResource LinkButton}"
                        Click="OpenKoFi_Click">
                    <TextBlock FontSize="12">
                        <Run Text="&#x2615; " /><Run Text="Ko-fi (Buy a Coffee)" Foreground="#0066CC" TextDecorations="Underline" />
                    </TextBlock>
                </Button>

                <Button Style="{StaticResource LinkButton}"
                        Click="OpenSponsors_Click">
                    <TextBlock FontSize="12">
                        <Run Text="&#x2764; " /><Run Text="GitHub Sponsors" Foreground="#0066CC" TextDecorations="Underline" />
                    </TextBlock>
                </Button>

                <Button Style="{StaticResource LinkButton}"
                        Click="OpenClaudeUsage_Click">
                    <TextBlock FontSize="12">
                        <Run Text="&#x1F4D6; " /><Run Text="Claude Usage Page" Foreground="#0066CC" TextDecorations="Underline" />
                    </TextBlock>
                </Button>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,16" />

        <!-- Developer Card -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Developer" />
                <TextBlock FontSize="12" Margin="0,0,0,4">
                    <Run Text="Made by " /><Run Text="f-is-h" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#888888">
                    <Run Text="Ported to Windows by " /><Run Text="Claude Code" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Diagnostics Card -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Diagnostics" />
                <TextBlock Style="{StaticResource HintText}" Text="View application logs for troubleshooting." Margin="0,0,0,8" />
                <Button Content="Open Logs Folder"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding OpenLogsFolderCommand}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <!-- Copyright -->
        <TextBlock Text="Copyright &#169; 2025 f-is-h. All rights reserved."
                   FontSize="10"
                   Foreground="#AAAAAA"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,16" />

    </StackPanel>
</UserControl>
