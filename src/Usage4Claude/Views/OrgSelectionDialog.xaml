<Window x:Class="Usage4Claude.Views.OrgSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Organization"
        Width="400" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header text -->
            <RowDefinition Height="*" />     <!-- ListBox -->
            <RowDefinition Height="Auto" />  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Multiple organizations found. Please select one:"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- Organization list -->
        <ListBox x:Name="OrgListBox"
                 Grid.Row="1"
                 SelectionChanged="OrgListBox_SelectionChanged"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 Margin="0,0,0,12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,3">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   FontWeight="Medium" />
                        <TextBlock FontSize="10"
                                   Foreground="#888888">
                            <TextBlock.Text>
                                <Binding Path="Uuid"
                                         StringFormat="ID: {0}" />
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="80"
                    Padding="0,5"
                    IsEnabled="False"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Width="80"
                    Padding="0,5"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
